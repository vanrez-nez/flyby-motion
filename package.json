{
  "name": "flyby-motion",
  "version": "0.0.0",
  "description": "A lightweight library for motion-driven DOM interactions.",
  "type": "module",
  "main": "./dist/flyby-motion.umd.js",
  "module": "./dist/flyby-motion.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/flyby-motion.es.js",
      "require": "./dist/flyby-motion.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --mode demos",
    "build": "vite build",
    "build:demos": "vite build --mode demos",
    "deploy": "npm run build:demos && npx -y gh-pages -d dist-demos -b docs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@tweakpane/core": "^2.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "pixi.js": "^8.18.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.184.0",
    "tweakpane": "^4.0.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.0"
  }
}
